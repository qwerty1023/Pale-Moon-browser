diff --git a/python/mozbuild/mozbuild/getencoding.py b/python/mozbuild/mozbuild/getencoding.py
new file mode 100644
index 0000000000..878bcf792d
--- /dev/null
+++ b/python/mozbuild/mozbuild/getencoding.py
@@ -0,0 +1,18 @@
+def getencoding():
+    import sys
+    import ctypes
+    from locale import getpreferredencoding
+
+    if sys.platform.startswith("win"):
+       try:
+          codepage = ctypes.windll.kernel32.GetConsoleOutputCP()
+          if codepage:
+              encoding = "cp%d" % codepage
+          else: 
+              encoding = getpreferredencoding(False)
+       except Exception:
+          encoding = getpreferredencoding(False)
+    else:
+       encoding = getpreferredencoding(False)
+
+    return encoding
